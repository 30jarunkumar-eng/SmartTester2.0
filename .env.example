# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows)

# ── API Provider ─────────────────────────────────────────────────────────────
# Choose ONE provider below and comment out the others.

# OPTION 1 — OpenAI directly (key starts with sk-...)
OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=                          # leave blank for default OpenAI

# OPTION 2 — OpenRouter (key starts with sk-or-...)
# OPENAI_API_KEY=sk-or-your-openrouter-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_PROVIDER=openrouter                # adds required OpenRouter headers

# OPTION 3 — NVIDIA NIM (key from build.nvidia.com)
# OPENAI_API_KEY=nvapi-your-nvidia-key-here
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_PROVIDER=nvidia

# ── Model selection ───────────────────────────────────────────────────────────
# OpenAI:      gpt-4o (default) | gpt-4o-mini | gpt-4-turbo
# OpenRouter:  openai/gpt-4o | anthropic/claude-3.5-sonnet | google/gemini-flash-1.5 | meta-llama/llama-3.1-70b-instruct:free
# NVIDIA NIM:  meta/llama-3.1-70b-instruct | nvidia/nemotron-4-340b-instruct | mistralai/mistral-large-latest
OPENAI_MODEL=gpt-4o

# ── Framework settings ────────────────────────────────────────────────────────
WORK_DIR=./work
CONFIDENCE_THRESHOLD=0.80
BROWSER=chromium
RECORD_TIMEOUT_MINUTES=10
